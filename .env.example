POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

CONFIG_SERVER_PORT=8888
DISCOVERY_SERVER_PORT=8761
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
DOCTOR_SERVICE_PORT=8082
APPOINTMENT_SERVICE_PORT=8083
NOTIFICATION_SERVICE_PORT=8084
FRONTEND_WEB_APP_PORT=5173
KAFKA_EXTERNAL_PORT=9094

AUTH_JWT_SECRET=replace-this-with-a-long-secret-key-at-least-32-bytes
AUTH_JWT_EXPIRATION_MS=3600000

NOTIFICATIONS_PROVIDER=log
NOTIFICATIONS_FROM_ADDRESS=no-reply@medical.local

# Solo para ejecucion local manual de config-server (mvn spring-boot:run).
# Docker Compose principal no necesita este valor porque monta /config-repo.
CONFIG_REPO_PATH=file:///ABSOLUTE/PATH/TO/medical-appointment-system/infrastructure/config-repo
